{
  "model_profile": "quality",
  "commit_docs": true,
  "parallelization": false,
  "search_gitignored": false,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": false,
  "tavily_search": false,
  "ref_search": false,
  "perplexity": false,
  "jina": false,
  "git": {
    "branching_strategy": "none",
    "create_tag": true,
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": false,
    "ui_safety_gate": false,
    "ai_integration_phase": true,
    "human_verify_mode": "end-of-phase",
    "text_mode": false,
    "research_before_questions": false,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "code_review_command": null,
    "pattern_mapper": true,
    "plan_bounce": false,
    "plan_bounce_script": null,
    "plan_bounce_passes": 2,
    "auto_prune_state": false,
    "post_planning_gaps": true,
    "security_enforcement": true,
    "security_asvs_level": 1,
    "security_block_on": "high",
    "_auto_chain_active": true
  },
  "ship": {
    "pr_body_sections": [
      {
        "heading": "Acceptance Criteria",
        "enabled": true,
        "source": "REQUIREMENTS.md ## Acceptance Criteria",
        "fallback": "- Acceptance criteria are covered by the linked requirements and verification evidence."
      },
      {
        "heading": "Risks & Rollback",
        "enabled": true,
        "source": "PLAN.md ## Risks || PLAN.md ## Rollback",
        "fallback": "- No known high-risk rollout risks; rollback via git revert."
      },
      {
        "heading": "Verification Evidence",
        "enabled": true,
        "source": "VERIFICATION.md ## Evidence || VERIFICATION.md ## Results",
        "fallback": "- Verification evidence attached on completion."
      },
      {
        "heading": "Security/Privacy Impact",
        "enabled": true,
        "source": "PLAN.md ## Security || PLAN.md ## Threat Model",
        "fallback": "- No security or privacy impact identified for this change."
      },
      {
        "heading": "Product/Architecture Decisions",
        "enabled": true,
        "source": "PLAN.md ## Decisions || ROADMAP.md ## Decisions",
        "fallback": "- Key product and architecture decisions recorded in the plan."
      }
    ]
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {},
  "claude_md_path": "./AGENTS.md",
  "plan_review": {
    "source_grounding": true,
    "source_grounding_authority": "grep"
  },
  "resolve_model_ids": "omit",
  "mode": "yolo",
  "granularity": "fine"
}
