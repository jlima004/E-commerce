# Environment contract for apps/backend (Medusa v2.16.0)
#
# Supported operational environments: local and production.
# staging is a documented convention only — not provisioned in Phase 01.
#
# Never commit real secrets. Copy to .env and fill values outside Git.

# --- Core ---
NODE_ENV=development
APP_VERSION=<release-or-commit-sha> # required in production; local defaults to dev when omitted
WORKER_MODE=shared # shared | server | worker
ADMIN_DISABLED=false # true | false

# --- Public URLs (required in production) ---
API_PUBLIC_URL=http://127.0.0.1:9000
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000

# --- Database ---
# Runtime uses DATABASE_URL (pooled/session). Migrations use DATABASE_MIGRATION_URL (direct/session).
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
DATABASE_MIGRATION_URL=postgresql://<user>:<password>@<host>:5432/<database> # required in production; never use port 6543

# --- Redis contracts (required in production; same instance may back all four URLs) ---
REDIS_URL=redis://127.0.0.1:6379
CACHE_REDIS_URL=redis://127.0.0.1:6379
EVENTS_REDIS_URL=redis://127.0.0.1:6379
WE_REDIS_URL=redis://127.0.0.1:6379

# --- Auth secrets (min 32 chars in production; no placeholder values) ---
JWT_SECRET=<generate-32-plus-char-secret>
COOKIE_SECRET=<generate-32-plus-char-secret>

# --- Supabase Storage ---
#S3_ENDPOINT=
#S3_REGION=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_FILE_URL=

# --- Observability ---
SENTRY_DSN=<https://public-key@o0.ingest.sentry.io/project-id> # required in production; optional in local
